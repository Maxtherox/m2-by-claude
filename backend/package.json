{
  "name": "metin2-rpg-backend",
  "version": "1.0.0",
  "description": "Backend for Metin2-inspired 2D RPG",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "setup": "knex migrate:latest --knexfile knexfile.js && knex seed:run --knexfile knexfile.js",
    "reset": "rimraf database.sqlite3 && npm run setup"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
